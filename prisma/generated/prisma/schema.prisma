generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())

  email    String? @unique
  number   String  @unique
  username String  @unique

  avatars  String[]
  bio      String?
  birthday DateTime?

  firstName String
  lastName  String

  contacts     UserContacts[]
  blockedUsers String[]       @default([])

  // privacy
  phoneVisible    WhoCanSeen @default(ALL)
  emailVisible    WhoCanSeen @default(ALL)
  bioVisible      WhoCanSeen @default(ALL)
  avatarsVisible  WhoCanSeen @default(ALL)
  birthdayVisible WhoCanSeen @default(ALL)

  // security
  cloudPassword String?

  // chats
  isOnline Boolean   @default(false)
  lastSeen DateTime?

  chatMembers ChatMember[]
  messages    Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Message {
  id String @id @default(uuid())

  text        String
  attachments Attachment[]
  chat        Chat         @relation(fields: [chatId], references: [id])
  chatId      String
  sender      User         @relation(fields: [senderId], references: [id])
  senderId    String
  isRead      Boolean      @default(false)
  editedAt    DateTime?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("messages")
}

model Attachment {
  id String @id @default(uuid())

  messageId String
  message   Message @relation(fields: [messageId], references: [id])
  uuidURI   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attachments")
}

model ChatMember {
  id String @id @default(uuid())

  chat     Chat     @relation(fields: [chatId], references: [id])
  chatId   String
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  joinedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chatMembers")
}

model Chat {
  id String @id @default(uuid())

  chatName String?
  isGroup  Boolean @default(false)

  members  ChatMember[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chats")
}

model UserContacts {
  id               String  @id @default(uuid())
  username         String
  user             User    @relation(fields: [username], references: [username])
  usernameContact  String
  firstNameContact String
  lastNameContact  String
  avatarsContact   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contacts")
}

model Codes {
  id        String   @id @default(uuid())
  number    String   @unique
  code      String
  isActived Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("codes")
}

enum WhoCanSeen {
  ALL
  CONTACTS
  I
}
